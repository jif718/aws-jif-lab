# Jenkins for EKS - jif-lab
# Adapted from lab cluster values.yaml, replacing Harbor with ECR

controller:
  componentName: "jenkins-controller"
  image:
    registry: "docker.io"
    repository: "jenkins/jenkins"
    tag: "2.555.1-lts"
    tagLabel: jdk21
    pullPolicy: "IfNotPresent"

  replicas: 1

  # No imagePullSecret needed (public docker.io image)

  disableRememberMe: false
  numExecutors: 0
  executorMode: "NORMAL"

  admin:
    username: "admin"
    userKey: jenkins-admin-user
    passwordKey: jenkins-admin-password
    createSecret: true       # Helm generates the secret
    existingSecret: ""

  jenkinsHome: "/var/jenkins_home"
  jenkinsRef: "/usr/share/jenkins/ref"
  jenkinsWar: "/usr/share/jenkins/jenkins.war"

  # Resource allocation - small for 2-node t4g.large cluster
  resources:
    requests:
      cpu: "250m"
      memory: "1Gi"
    limits:
      cpu: "1500m"
      memory: "2Gi"

  enableServiceLinks: false

  # JVM tuning - container-aware heap sizing
  javaOpts: "-XX:MaxRAMPercentage=70.0 -Dhudson.slaves.NodeProvisioner.initialDelay=0 -Dhudson.slaves.NodeProvisioner.MARGIN=50 -Dhudson.slaves.NodeProvisioner.MARGIN0=0.85"

  # Plain HTTP for now - will switch to HTTPS after ALB Ingress is installed
  jenkinsUrlProtocol: http
  jenkinsUrl: "http://jenkins.jenkins.svc.cluster.local:8080"

  usePodSecurityContext: true
  runAsUser: 1000
  fsGroup: 1000
  fsGroupChangePolicy: OnRootMismatch

  serviceType: ClusterIP
  servicePort: 8080
  targetPort: 8080

  # Plugin management
  installPlugins:
    - kubernetes
    - workflow-aggregator
    - git
    - configuration-as-code
    - credentials
    - plain-credentials
    - ssh-credentials
    - github
    - github-branch-source
    - pipeline-stage-view
    - amazon-ecr             # ECR auth helper
    - aws-credentials        # AWS credentials provider
    - timestamper
    - ws-cleanup
    - job-dsl

  installLatestPlugins: false
  installLatestSpecifiedPlugins: false
  additionalPlugins: []
  initializeOnce: true
  overwritePlugins: false
  overwritePluginsFromImage: true

  projectNamingStrategy: standard
  enableRawHtmlMarkupFormatter: false

  # JCasC - declarative config (preferred over UI clicks)
  JCasC:
    defaultConfig: false
    overwriteConfiguration: true
    configScripts:
      # GitHub credentials (PAT for cloning repos)
      # Reference: ${jenkins-credentials-XXX} reads from secret 'jenkins-credentials' key 'XXX'
      credentials: |
        credentials:
          system:
            domainCredentials:
              - credentials:
                  - usernamePassword:
                      scope: GLOBAL
                      id: "github-token"
                      username: "${jenkins-credentials-GITHUB_USERNAME}"
                      password: "${jenkins-credentials-GITHUB_PAT}"
                      description: "GitHub Personal Access Token"

      # Kubernetes cloud + agent templates
      kubernetes-cloud-and-agents: |
        jenkins:
          clouds:
            - kubernetes:
                name: "kubernetes"
                serverUrl: "https://kubernetes.default"
                namespace: "jenkins"
                jenkinsUrl: "http://jenkins.jenkins.svc.cluster.local:8080/"
                # No jenkinsTunnel needed - using HTTP inbound (TCP 50000 disabled)
                containerCapStr: "10"
                maxRequestsPerHostStr: "32"
                retentionTimeout: 5
                waitForPodSec: 600
                connectTimeout: 100
                readTimeout: 15
                podLabels:
                  - key: "jenkins/jenkins-jenkins-agent"
                    value: "true"
                templates:
                  # General-purpose Python agent for scripted tasks
                  - name: "python-agent"
                    namespace: "jenkins"
                    label: "python"
                    nodeUsageMode: "NORMAL"
                    podRetention: "never"
                    serviceAccount: "jenkins-agent"
                    idleMinutes: 0
                    instanceCap: 10
                    slaveConnectTimeoutStr: "100"
                    yamlMergeStrategy: "override"
                    showRawYaml: true
                    workspaceVolume:
                      emptyDirWorkspaceVolume:
                        memory: false
                    nodeSelector: "kubernetes.io/os=linux"
                    containers:
                      - name: "jnlp"
                        image: "jenkins/inbound-agent:3273.v4cfe589b_fd33-2"
                        alwaysPullImage: false
                        workingDir: "/home/jenkins/agent"
                        ttyEnabled: true
                        resourceRequestCpu: "100m"
                        resourceRequestMemory: "256Mi"
                        resourceLimitCpu: "500m"
                        resourceLimitMemory: "768Mi"

                  # Kaniko agent - builds images and pushes to ECR via IRSA
                  - name: "kaniko-agent"
                    namespace: "jenkins"
                    label: "kaniko"
                    nodeUsageMode: "NORMAL"
                    podRetention: "never"
                    serviceAccount: "jenkins-agent"
                    idleMinutes: 0
                    instanceCap: 5
                    slaveConnectTimeoutStr: "100"
                    yamlMergeStrategy: "override"
                    showRawYaml: true
                    workspaceVolume:
                      emptyDirWorkspaceVolume:
                        memory: false
                    nodeSelector: "kubernetes.io/os=linux"
                    # No volumes needed - Kaniko on EKS uses IRSA via IMDS
                    containers:
                      - name: "jnlp"
                        image: "jenkins/inbound-agent:3273.v4cfe589b_fd33-2"
                        alwaysPullImage: false
                        workingDir: "/home/jenkins/agent"
                        ttyEnabled: true
                        resourceRequestCpu: "100m"
                        resourceRequestMemory: "256Mi"
                        resourceLimitCpu: "500m"
                        resourceLimitMemory: "768Mi"
                      - name: "kaniko"
                        image: "gcr.io/kaniko-project/executor:v1.24.0-debug"
                        alwaysPullImage: false
                        workingDir: "/workspace"
                        command: "sleep"
                        args: "99d"
                        ttyEnabled: true
                        resourceRequestCpu: "250m"
                        resourceRequestMemory: "512Mi"
                        resourceLimitCpu: "1500m"
                        resourceLimitMemory: "1.5Gi"

        unclassified:
          location:
            # Will update to https://jenkins.<your-domain> after ALB Ingress is set up
            url: "http://jenkins.jenkins.svc.cluster.local:8080/"

    security:
      apiToken:
        creationOfLegacyTokenEnabled: false
        tokenGenerationOnCreationEnabled: false
        usageStatisticsEnabled: true

    securityRealm: |-
      local:
        allowsSignup: false
        enableCaptcha: false
        users:
        - id: "${chart-admin-username}"
          name: "Jenkins Admin"
          password: "${chart-admin-password}"

    authorizationStrategy: |-
      loggedInUsersCanDoAnything:
        allowAnonymousRead: false

    configMapAnnotations: {}

  customInitContainers: []

  # Probes - controller starts slow, give it time
  probes:
    startupProbe:
      httpGet:
        path: '{{ default "" .Values.controller.jenkinsUriPrefix }}/login'
        port: http
      periodSeconds: 10
      timeoutSeconds: 5
      failureThreshold: 30
    livenessProbe:
      failureThreshold: 5
      httpGet:
        path: '{{ default "" .Values.controller.jenkinsUriPrefix }}/login'
        port: http
      periodSeconds: 10
      timeoutSeconds: 5
    readinessProbe:
      failureThreshold: 3
      httpGet:
        path: '{{ default "" .Values.controller.jenkinsUriPrefix }}/login'
        port: http
      periodSeconds: 10
      timeoutSeconds: 5

  # No JNLP listener (TCP 50000) - using inbound HTTP agents
  agentListenerEnabled: false

  # Reuse SA created by eksctl with IRSA annotation
  serviceAccount:
    create: false
    name: jenkins

# Persistence - EBS gp3
persistence:
  enabled: true
  storageClass: "gp3"
  accessMode: "ReadWriteOnce"
  size: "10Gi"

# RBAC
rbac:
  create: true
  readSecrets: false
  useOpenShiftNonRootSCC: false

# Top-level serviceAccount block - must align with controller.serviceAccount
serviceAccount:
  create: false
  name: jenkins
  automountServiceAccountToken: true

# Agent SA - Helm creates it, eksctl adds IRSA annotation after install
serviceAccountAgent:
  create: true
  name: jenkins-agent
  automountServiceAccountToken: true

# Don't use the chart's default agent block - we define agents via JCasC podTemplates
agent:
  enabled: false

networkPolicy:
  enabled: false

checkDeprecation: true
